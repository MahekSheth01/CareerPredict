# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/career-predictor

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email Configuration
# Option A (recommended for cloud): Get a free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Option B (fallback): Gmail SMTP with App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@careerpredictor.com

# Frontend URL — MUST match your deployed Vercel URL in production
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# AI Service URL
# Production: https://ai-service-hsi2.onrender.com
AI_SERVICE_URL=http://localhost:8000
